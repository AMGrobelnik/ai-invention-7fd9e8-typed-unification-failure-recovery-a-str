\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Cache hit rate as pipeline processes documents 1--50 in same domain (legal contracts). Initial documents (1--10) have 0\% hit rate (no prior axioms). By document 31--50, hit rate reaches 41\%, demonstrating lexical bridge axioms transfer within domain. This reduces per-document LLM calls and improves consistency. Saturation at 41\% reflects domain-vocabulary limits and emergence of stable naming conventions.}}{11}{figure.4}\protected@file@percent }
\newlabel{fig:accumulation}{{4}{11}{Cache hit rate as pipeline processes documents 1--50 in same domain (legal contracts). Initial documents (1--10) have 0\% hit rate (no prior axioms). By document 31--50, hit rate reaches 41\%, demonstrating lexical bridge axioms transfer within domain. This reduces per-document LLM calls and improves consistency. Saturation at 41\% reflects domain-vocabulary limits and emergence of stable naming conventions}{figure.4}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.2}Limitations}{11}{subsection.5.2}\protected@file@percent }
